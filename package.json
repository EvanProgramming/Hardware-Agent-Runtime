{
  "name": "carduino",
  "version": "0.1.0",
  "private": true,
  "description": "Hardware Agent Runtime (HAR) v1.0 MVP",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "tsc -b",
    "check": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "har": "tsx packages/cli/src/main.ts",
    "mcp": "node packages/mcp/dist/server.js",
    "ci": "tsx packages/cli/src/ci.ts",
    "setup": "npm run build && node scripts/setup.mjs",
    "mcp:install": "node scripts/register-mcp.mjs",
    "mcp:remove": "codex mcp remove hardware-agent-runtime"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/better-sqlite3": "^7.6.12",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "better-sqlite3": "^11.7.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "serialport": "^12.0.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.2"
  }
}
