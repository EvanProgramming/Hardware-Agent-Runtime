{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://github.com/EvanProgramming/Hardware-Agent-Runtime/schemas/har-v1.schema.json",
  "title":"HAR v1 core contracts",
  "oneOf":[
    {"$ref":"#/$defs/ProjectState"},{"$ref":"#/$defs/BoardDescriptor"},{"$ref":"#/$defs/ComponentInstance"},{"$ref":"#/$defs/PinDefinition"},{"$ref":"#/$defs/Connection"},{"$ref":"#/$defs/FirmwareArtifact"},{"$ref":"#/$defs/HardwareContext"},{"$ref":"#/$defs/DiagnosticReport"},{"$ref":"#/$defs/DiagnosticFinding"},{"$ref":"#/$defs/SerialObservation"},{"$ref":"#/$defs/UsbObservation"},{"$ref":"#/$defs/DriverDefinition"},{"$ref":"#/$defs/ExperimentDefinition"},{"$ref":"#/$defs/ExperimentStep"},{"$ref":"#/$defs/ExperimentRun"},{"$ref":"#/$defs/HumanActionRequest"},{"$ref":"#/$defs/HumanActionResponse"},{"$ref":"#/$defs/VerificationEvidence"},{"$ref":"#/$defs/VerificationReport"},{"$ref":"#/$defs/ResourceReport"},{"$ref":"#/$defs/SimulationState"},{"$ref":"#/$defs/RuntimeEvent"},{"$ref":"#/$defs/ErrorEnvelope"}
  ],
  "$defs": {
    "base":{"type":"object","required":["apiVersion","id"],"properties":{"apiVersion":{"const":"har/v1"},"id":{"type":"string","minLength":1},"revision":{"type":"integer","minimum":1},"createdAt":{"type":"string","format":"date-time"}},"additionalProperties":true},
    "ProjectState":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","lifecycle","hardwareModelId"],"properties":{"kind":{"const":"ProjectState"},"lifecycle":{"enum":["created","hardware_planning","waiting_for_user","ready_to_build","compiling","flashing","observing","experimenting","verifying","completed","failed","blocked"]},"hardwareModelId":{"type":"string"}}}]},
    "BoardDescriptor":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","adapterId","platform","fqbn","pins"],"properties":{"kind":{"const":"BoardDescriptor"},"adapterId":{"type":"string"},"platform":{"type":"string"},"fqbn":{"type":"string"},"pins":{"type":"array","items":{"$ref":"#/$defs/PinDefinition"}}}}]},
    "ComponentInstance":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","driverId","stateOrigin"],"properties":{"kind":{"const":"ComponentInstance"},"driverId":{"type":"string"},"stateOrigin":{"$ref":"#/$defs/origin"},"properties":{"type":"object"}}}]},
    "PinDefinition":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","name","capabilities"],"properties":{"kind":{"const":"PinDefinition"},"name":{"type":"string"},"capabilities":{"type":"array","items":{"enum":["digital_in","digital_out","analog_in","pwm","i2c","spi","uart","power","ground"]}}}}]},
    "Connection":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","from","to","stateOrigin"],"properties":{"kind":{"const":"Connection"},"from":{"type":"string"},"to":{"type":"string"},"stateOrigin":{"$ref":"#/$defs/origin"}}}]},
    "FirmwareArtifact":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","digest","boardFqbn","buildStatus"],"properties":{"kind":{"const":"FirmwareArtifact"},"digest":{"type":"string"},"boardFqbn":{"type":"string"},"buildStatus":{"enum":["compiled","failed"]}}}]},
    "HardwareContext":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","projectId","modelRevision","observations"],"properties":{"kind":{"const":"HardwareContext"},"projectId":{"type":"string"},"modelRevision":{"type":"integer"},"observations":{"type":"array","items":{"type":"string"}}}}]},
    "DiagnosticReport":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","findings"],"properties":{"kind":{"const":"DiagnosticReport"},"findings":{"type":"array","items":{"$ref":"#/$defs/DiagnosticFinding"}}}}]},
    "DiagnosticFinding":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","ruleId","confidence","evidenceIds"],"properties":{"kind":{"const":"DiagnosticFinding"},"ruleId":{"type":"string"},"confidence":{"type":"number","minimum":0,"maximum":1},"evidenceIds":{"type":"array","items":{"type":"string"}}}}]},
    "SerialObservation":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","timestamp","bytes","source"],"properties":{"kind":{"const":"SerialObservation"},"timestamp":{"type":"string","format":"date-time"},"bytes":{"type":"string","contentEncoding":"base64"},"source":{"const":"runtime"}}}]},
    "UsbObservation":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","timestamp","event","fingerprint"],"properties":{"kind":{"const":"UsbObservation"},"timestamp":{"type":"string","format":"date-time"},"event":{"enum":["attached","detached","changed"]},"fingerprint":{"type":"string"}}}]},
    "DriverDefinition":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","version","capabilities"],"properties":{"kind":{"const":"DriverDefinition"},"version":{"type":"string"},"capabilities":{"type":"array","items":{"type":"string"}}}}]},
    "ExperimentDefinition":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","version","steps"],"properties":{"kind":{"const":"ExperimentDefinition"},"version":{"type":"string"},"steps":{"type":"array","items":{"$ref":"#/$defs/ExperimentStep"}}}}]},
    "ExperimentStep":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","type","timeoutMs"],"properties":{"kind":{"const":"ExperimentStep"},"type":{"enum":["compile","flash","reset","serial_capture","wait_for","assert","repeat","human_action","branch","collect_evidence","cleanup"]},"timeoutMs":{"type":"integer","minimum":1}}}]},
    "ExperimentRun":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","definitionId","status"],"properties":{"kind":{"const":"ExperimentRun"},"definitionId":{"type":"string"},"status":{"enum":["pending","running","waiting_for_human","resumed","passed","failed","aborted","timed_out"]}}}]},
    "HumanActionRequest":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","runId","token","expiresAt"],"properties":{"kind":{"const":"HumanActionRequest"},"runId":{"type":"string"},"token":{"type":"string"},"expiresAt":{"type":"string","format":"date-time"}}}]},
    "HumanActionResponse":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","requestId","token","response"],"properties":{"kind":{"const":"HumanActionResponse"},"requestId":{"type":"string"},"token":{"type":"string"},"response":{"type":"object"}}}]},
    "VerificationEvidence":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","digest","source","stateOrigin"],"properties":{"kind":{"const":"VerificationEvidence"},"digest":{"type":"string"},"source":{"enum":["serial","usb","toolchain","human","simulation"]},"stateOrigin":{"$ref":"#/$defs/origin"}}}]},
    "VerificationReport":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","verdict","evidenceIds"],"properties":{"kind":{"const":"VerificationReport"},"verdict":{"enum":["passed","failed","inconclusive"]},"evidenceIds":{"type":"array","items":{"type":"string"}}}}]},
    "ResourceReport":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","status","items"],"properties":{"kind":{"const":"ResourceReport"},"status":{"enum":["safe","warning","blocked"]},"items":{"type":"array","items":{"type":"object"}}}}]},
    "SimulationState":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","engineId","status"],"properties":{"kind":{"const":"SimulationState"},"engineId":{"type":"string"},"status":{"enum":["ready","running","completed","failed"]}}}]},
    "RuntimeEvent":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","sequence","type","payload"],"properties":{"kind":{"const":"RuntimeEvent"},"sequence":{"type":"integer","minimum":1},"type":{"type":"string"},"payload":{"type":"object"}}}]},
    "ErrorEnvelope":{"allOf":[{"$ref":"#/$defs/base"},{"required":["kind","code","category","message","stage","retryable","evidence"],"properties":{"kind":{"const":"ErrorEnvelope"},"code":{"type":"string"},"category":{"enum":["user_action_required","hardware_unavailable","toolchain_failure","compile_failure","flash_failure","runtime_failure","experiment_failure","internal_har_failure"]},"message":{"type":"string"},"stage":{"type":"string"},"retryable":{"type":"boolean"},"evidence":{"type":"array","items":{"type":"string"}},"suggested_next_action":{"type":"string"},"underlying_tool_error":{"type":"string"}}}]},
    "origin":{"enum":["user_reported","runtime_observed","inferred","verified"]}
  }
}
